# Copia este archivo como .env y configura los valores

# Base de datos (SQLite para desarrollo, PostgreSQL para producción)
DATABASE_URL=sqlite:///./encuestas.db
# DATABASE_URL=postgresql://usuario:password@localhost:5432/encuestas

# Clave de acceso al panel de administración — CÁMBIALA
ADMIN_KEY=cambia_esta_clave_segura
